{
  "name": "gent",
  "version": "0.2.0",
  "description": "Coding-agent environment profile manager and project/task tracker for Claude Code, Pi, and Codex",
  "license": "MIT",
  "author": "jorbraken",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorbraken/gent.git"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "bin": {
    "gent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && pnpm --filter gent-ui build",
    "build:cli": "tsup",
    "build:extension": "pnpm --filter gent-ui vsix",
    "build:containers": "pnpm --filter @gent/containers build",
    "global": "pnpm build && npm link",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:extension": "pnpm --filter gent-ui test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && pnpm --filter gent-ui typecheck"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
