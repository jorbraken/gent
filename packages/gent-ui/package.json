{
  "name": "gent-ui",
  "displayName": "Gent UI",
  "description": "Visual source-aware editor for Gent profiles, sandboxes, context, skills, memories, decisions, and pipelines.",
  "version": "0.1.0",
  "publisher": "gent",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorbraken/gent.git",
    "directory": "packages/gent-ui"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:gent.refresh"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gent",
          "title": "Gent",
          "icon": "resources/gent.svg"
        }
      ]
    },
    "views": {
      "gent": [
        {
          "id": "gent.entities",
          "name": "Gent"
        }
      ]
    },
    "commands": [
      {
        "command": "gent.refresh",
        "title": "Gent: Refresh"
      },
      {
        "command": "gent.openEntity",
        "title": "Gent: Open Entity"
      },
      {
        "command": "gent.createEntity",
        "title": "Gent: Create Entity"
      },
      {
        "command": "gent.deleteEntity",
        "title": "Gent: Delete Entity"
      },
      {
        "command": "gent.revealSource",
        "title": "Gent: Reveal Source"
      },
      {
        "command": "gent.inspectProfile",
        "title": "Gent: Inspect Profile"
      },
      {
        "command": "gent.previewProfile",
        "title": "Gent: Preview Profile"
      },
      {
        "command": "gent.sandbox.validate",
        "title": "Gent: Sandbox Validate"
      },
      {
        "command": "gent.sandbox.run",
        "title": "Gent: Sandbox Run"
      },
      {
        "command": "gent.sandbox.logs",
        "title": "Gent: Sandbox Logs"
      },
      {
        "command": "gent.sandbox.stop",
        "title": "Gent: Sandbox Stop"
      },
      {
        "command": "gent.sandbox.destroy",
        "title": "Gent: Sandbox Destroy"
      }
    ]
  },
  "scripts": {
    "build": "tsup",
    "package": "vsce package --no-dependencies -o gent-ui.vsix",
    "vsix": "pnpm build && pnpm package",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
